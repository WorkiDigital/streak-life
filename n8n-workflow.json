    {
      "parameters": {
        "jsCode": "const data = $input.all();\nconst items = Array.isArray(data[0]?.json) ? data[0].json : data.map(i => i.json);\n\nreturn items.map(item => {\n  let parsedPush = null;\n  if (item.push_token) {\n    try {\n      const p = typeof item.push_token === 'string' ? JSON.parse(item.push_token) : item.push_token;\n      if (typeof p === 'object' && p !== null && p.endpoint) parsedPush = p;\n    } catch (e) {}\n  }\n  \n  return {\n    json: {\n      ...item,\n      push_token: parsedPush,\n      canais: Array.isArray(item.canais) ? item.canais : [item.canais].filter(Boolean)\n    }\n  };\n});"
      },
